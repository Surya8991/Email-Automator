# env / secrets
.env
.env.*.local

# DB / data
*.db
*.db-journal
# Ignore contents of data/ (sqlite, runtime artifacts) but keep the
# directory traversable so explicit allowlists below can re-include files.
data/*
# …but DO ship the seed templates — onboarding loads them at first sign-in,
# and Vercel needs the files in the build to populate new users' libraries.
!data/seed-templates.json
!data/seed-templates.admin.json

# logs
*.log

