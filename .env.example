# Auth
AUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Encryption at rest for SMTP_PASS + GROQ_API_KEY. Recommended on hosted
# envs — decouples credential encryption from AUTH_SECRET. Generate with
# `openssl rand -base64 32`. If unset, key derives from AUTH_SECRET.
ENCRYPTION_KEY=

# Email provider (magic-link login + outbound mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Email Automator <you@gmail.com>"

# Google OAuth (optional — also unlocks Gmail-API features)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — secondary social sign-in)
# Create at https://github.com/settings/developers → New OAuth App.
# Callback URL: https://<your-app>/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Database
# Local dev (better-sqlite3 file):  ./data/tracker.db
# Vercel / Turso (libSQL):          libsql://<your-db>.turso.io
DATABASE_URL=./data/tracker.db
# Required when DATABASE_URL is libsql://... — paste the Turso auth token
TURSO_AUTH_TOKEN=

# Vercel cron secret — set to a long random string in Vercel env vars.
# /api/cron/tick checks `Authorization: Bearer ${CRON_SECRET}` (Vercel sets
# it automatically) or `?secret=` query param.
CRON_SECRET=

# Groq (AI assist) — free tier covers light usage. Get a key at
# https://console.groq.com. Default model is llama-3.3-70b-versatile.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Admin emails (comma-separated)
ADMIN_EMAILS=you@gmail.com

# Dev sign-in: lets you log in as one of DEV_BYPASS_EMAILS without SMTP/Google.
# Off by default in production. Turn off the moment Google OAuth is configured.
ALLOW_DEV_SIGNIN=false
DEV_BYPASS_EMAILS=test@gmail.com

# Misc
APP_URL=http://localhost:3000
DAILY_SEND_LIMIT=50
TIMEZONE=Asia/Kolkata

# ── Production hardening (all optional) ──────────────────────────────
# Set HSTS_APEX=true ONLY when deploying to your own apex domain
# (your-app.com). On shared *.vercel.app preview URLs leave it off — the
# strong HSTS form (includeSubDomains; preload) would force HSTS on every
# other app on the platform AND a preload submission from a non-apex
# eTLD+1 is invalid. Default falls back to host-only `max-age=15552000`.
HSTS_APEX=false

# Redis URL for the rate limiter. lib/rate-limit.ts uses an in-memory
# Map by default — fine for single-instance self-hosted, but on Vercel
# (multi-instance Lambdas) the effective limit is `max × instance_count`.
# Wire Upstash Redis when ready; until then the limits are advisory.
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tells lib/rate-limit.ts to log the multi-instance warning even outside
# Vercel — useful when self-hosting behind a load balancer.
MULTI_INSTANCE=false

# CSP nonce middleware (opt-in). Enables a strict CSP that requires
# nonce-bearing <script> tags. Requires every inline script in the app
# (Next runtime, Recharts, sonner) to thread the x-nonce header through
# next/headers. Leave off until the audit is done.
CSP_NONCE=false
